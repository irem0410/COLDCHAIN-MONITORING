par ColdChainNetwork.sensor[2] numApps 1
par ColdChainNetwork.sensor[2] deploymentType "\"\""
par ColdChainNetwork.sensor[2] maxGatewayDistance 320
par ColdChainNetwork.sensor[2] gatewayX 320
par ColdChainNetwork.sensor[2] gatewayY 320
par ColdChainNetwork.sensor[2] humidity 40
par ColdChainNetwork.sensor[2] humThreshold 55
par ColdChainNetwork typename "\"ColdChainNetwork\""
par ColdChainNetwork numSensors 3

